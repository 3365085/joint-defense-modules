{
  "package": "module_a_latest_frame_pipeline_v5",
  "created_at": "2026-05-17",
  "summary": "MP4 BrowserFrameSource refactored to latest-only mailbox detection pipeline; no historical frame queue; stale overlays are not painted.",
  "key_changes": [
    "Browser <video> remains the only MP4 playback clock.",
    "Frontend samples only actually painted frames using requestVideoFrameCallback when available.",
    "Backend keeps a single latest-frame mailbox for browser frames; slow detection overwrites old pending frames instead of queuing.",
    "First frame still runs synchronously before preview becomes visible.",
    "Canvas refuses to paint overlay records older than overlay_max_age_ms.",
    "A3b confirmed score remains separated from observed score, and p_synth runtime/web branch remains removed."
  ],
